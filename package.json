{
	"name": "better-svelte-email-monorepo",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.3",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "bun run --cwd apps/docs dev",
		"build": "turbo run build",
		"test": "turbo run test",
		"lint": "turbo run lint",
		"check": "turbo run check",
		"package": "turbo run package",
		"format": "prettier --write .",
		"ci:version": "changeset version",
		"ci:publish": "bash ./scripts/ci-publish.sh"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "24.10.9",
		"concurrently": "^9.2.1",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"publint": "^0.3.18",
		"shiki": "^4.0.2",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.6",
		"svelte-themes": "^2.0.10",
		"tsdown": "^0.21.7",
		"turbo": "^2.9.3",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vite": "^8.0.3",
		"vitest": "^4.1.2"
	}
}
