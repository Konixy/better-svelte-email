{
	"name": "@better-svelte-email/cli",
	"description": "CLI for better-svelte-email",
	"version": "2.0.0",
	"scripts": {
		"dev": "bun --watch src/index.ts dev --preview-dev --preview-port 3001 -d ../../apps/docs/src/lib/emails -c ../../apps/docs/src/app.css",
		"build:cli": "tsdown",
		"build": "bun run build:cli",
		"lint": "prettier --check . --ignore-path ../../.prettierignore && eslint src",
		"test": "vitest run"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Konixy/better-svelte-email.git",
		"directory": "packages/cli"
	},
	"module": "./dist/index.mjs",
	"type": "module",
	"main": "./dist/index.cjs",
	"bin": {
		"bse": "./dist/index.cjs"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		},
		"./package.json": "./package.json"
	},
	"dependencies": {
		"@better-svelte-email/preview-server": "workspace:*",
		"@better-svelte-email/server": "workspace:*",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"chokidar": "^5.0.0",
		"commander": "^14.0.3",
		"prettier": "^3.8.1",
		"svelte": "^5.55.1",
		"vite": "^8.0.3"
	},
	"types": "./dist/index.d.cts"
}
