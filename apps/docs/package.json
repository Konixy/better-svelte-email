		"clsx": "^2.1.1",
		"mdsvex": "^0.12.7",
		"mode-watcher": "^1.1.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-slug": "^6.0.0",
		"resend": "^6.12.3",
		"shiki": "^4.1.0",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.0",
		"tailwindcss-motion": "^1.1.1",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
